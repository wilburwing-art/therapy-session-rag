  "description": "TherapyRAG core signals: API latency, operation durations, HTTP error rate.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-therapyrag"
      },
      "description": "Request rate by HTTP route, exported by the FastAPI OTEL instrumentation.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-therapyrag"
          },
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count{service_name=~\"therapyrag.*\"}[5m]))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ],
      "title": "API request rate (by route)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-therapyrag"
      },
      "description": "p95 HTTP server latency per route.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-therapyrag"
          },
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket{service_name=~\"therapyrag.*\"}[5m])))",
          "legendFormat": "p95 {{http_route}}",
          "refId": "A"
        }
      ],
      "title": "API p95 latency (by route)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-therapyrag"
      },
      "description": "HTTP 5xx error rate as a fraction of total requests.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-therapyrag"
          },
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=~\"therapyrag.*\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=~\"therapyrag.*\"}[5m])), 1)",
          "legendFormat": "5xx rate",
          "refId": "A"
        }
      ],
      "title": "API 5xx error rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-therapyrag"
      },
      "description": "Duration of instrumented business operations (chat.rag, summarization.recap, worker.transcription). p95.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-therapyrag"
          },
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(therapyrag_operation_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{operation}}",
          "refId": "A"
        }
      ],
      "title": "Business op p95 duration",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-therapyrag"
      },
      "description": "Business operation throughput.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-therapyrag"
          },
          "expr": "sum by (operation) (rate(therapyrag_operation_duration_seconds_count[5m]))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "title": "Business op rate",
      "type": "timeseries"
    }
